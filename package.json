  },
  "keywords": [
    "obsidian",
    "plugin",
    "handwriting",
    "markdown"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@codemirror/state": "6.5.0",
    "@codemirror/view": "6.38.6",
    "@types/node": "^20.17.24",
    "builtin-modules": "^3.3.0",
    "esbuild": "^0.25.1",
    "obsidian": "^1.7.2",
    "tslib": "^2.8.1",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
