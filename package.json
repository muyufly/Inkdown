{
  "name": "inkdown",
  "version": "0.1.0",
  "description": "Inline handwritten ink blocks for Obsidian Markdown notes.",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
